# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/db0.db

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false

# ── Auto-selection ────────────────────────────────────────────────────────────
# Items with fewer ratings than this use hybrid; at or above it → collaborative.
HYBRID_THRESHOLD=5

# ── Hybrid recommender ────────────────────────────────────────────────────────
# Default weight for the collaborative signal (1 - HYBRID_ALPHA weights content-based).
HYBRID_ALPHA=0.5
# Candidate pool = nrec × this multiplier. Larger → better recall, slower.
HYBRID_POOL_MULTIPLIER=3

# ── Collaborative filtering ───────────────────────────────────────────────────
# Items with fewer ratings than this are excluded from the user-item matrix.
COLLAB_POPULARITY_THRESHOLD=1
# Users with fewer ratings than this are excluded from the user-item matrix.
COLLAB_ACTIVITY_THRESHOLD=1
# Hard cap on rating rows loaded into memory.
COLLAB_MAX_RATINGS=2000000
# k for the KNN model. Must be greater than the maximum nrec the API can return.
COLLAB_N_NEIGHBORS=20

# ── Content-based filtering ───────────────────────────────────────────────────
# Upper bound of TF-IDF n-gram range (lower bound is always 1).
CONTENT_NGRAM_MAX=3
# Minimum document frequency for a term to be included in the TF-IDF matrix.
CONTENT_MIN_DF=1

# ── Fuzzy matching (used by all recommenders) ─────────────────────────────────
# Minimum fuzz.ratio score (0–100) to accept a title as a match.
FUZZY_MATCH_THRESHOLD=60

# ── Security ──────────────────────────────────────────────────────────────────
# Set DISABLE_SECURITY=true for local sandbox testing ONLY.
# When true: authentication is bypassed, any credentials return a token,
#            rate limiting is disabled, and Swagger shows a sandbox banner.
# NEVER deploy with this flag enabled.
DISABLE_SECURITY=false

# Secret used to sign JWTs. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be overridden in production — the default value is public and insecure.
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION

# JWT settings.
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Default admin account created on first start. Change before deployment.
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=changeme

# Comma-separated list of allowed CORS origins. Use * to allow all (dev default).
CORS_ORIGINS=*

# Sliding-window rate limit: max requests per IP in RATE_LIMIT_PERIOD seconds.
# In production, use a Redis-backed limiter (e.g. slowapi + Redis) instead.
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# ── Hardware acceleration ──────────────────────────────────────────────────────
# Backend used for ML operations inside the recommenders.
#
#   none  (default) — standard CPU sklearn, no extra dependencies
#   intel           — Intel Extension for Scikit-learn (pip install scikit-learn-intelex)
#                     Patches sklearn globally to use MKL/DNNL on Intel CPUs.
#                     Accelerates KNN (collaborative) and TF-IDF (content-based).
#   cuda            — RAPIDS cuML + CuPy (requires a CUDA-capable GPU and the RAPIDS stack)
#                     Uses cuML's NearestNeighbors for collaborative filtering
#                     and CuPy for the cosine-similarity matrix in content-based.
#
# Falls back to 'none' with a warning if the requested library is not installed.
HARDWARE_BACKEND=none
